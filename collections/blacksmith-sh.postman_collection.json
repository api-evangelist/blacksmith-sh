      "id": "9d2c1b00-0010-4a10-9c01-blacksmith0010",
      "name": "Testbox CLI",
      "description": {
        "content": "Blacksmith Testbox CLI (beta) - the documented programmatic surface. Lets coding agents run CI against local changes instantly.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "9d2c1b00-0011-4a10-9c01-blacksmith0011",
          "name": "blacksmith testbox warmup",
          "request": {
            "name": "blacksmith testbox warmup",
            "description": {
              "content": "Dispatches a testbox and returns an ID immediately. Required before any run command. Flags: --idle-timeout, --job, --ref, --ssh-public-key. Example: blacksmith testbox warmup blacksmith-testbox.yml",
              "type": "text/plain"
            },
            "url": {
              "raw": "https://docs.blacksmith.sh/blacksmith-testbox/cli",
              "protocol": "https",
              "host": ["docs", "blacksmith", "sh"],
              "path": ["blacksmith-testbox", "cli"],
              "query": [],
              "variable": []
            },
            "header": [],
            "method": "GET",
            "auth": null
          },
          "response": []
        },
        {
          "id": "9d2c1b00-0012-4a10-9c01-blacksmith0012",
          "name": "blacksmith testbox run",
          "request": {
            "name": "blacksmith testbox run",
            "description": {
              "content": "Syncs local changes (rsync --delete --checksum) and executes a command on the testbox, blocking until ready. Flags: --id, --debug, --ssh-private-key. Exits with the remote command's exit code. Example: blacksmith testbox run --id tbx_... \"npm test\"",
              "type": "text/plain"
            },
            "url": {
              "raw": "https://docs.blacksmith.sh/blacksmith-testbox/cli",
              "protocol": "https",
              "host": ["docs", "blacksmith", "sh"],
              "path": ["blacksmith-testbox", "cli"],
              "query": [],
              "variable": []
            },
            "header": [],
            "method": "GET",
            "auth": null
          },
          "response": []
        },
        {
