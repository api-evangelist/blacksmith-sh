      "id": "9d2c1b00-0001-4a10-9c01-blacksmith0001",
      "name": "About This Collection",
      "description": {
        "content": "Blacksmith does not publish a documented public REST API. It is integrated as a GitHub App and used via GitHub Actions runner tags (runs-on) and useblacksmith/* Actions. The only documented scriptable surface is the Blacksmith Testbox CLI. This collection documents that real surface rather than fabricating HTTP endpoints.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "9d2c1b00-0002-4a10-9c01-blacksmith0002",
          "name": "Install the Blacksmith GitHub App",
          "request": {
            "name": "Install the Blacksmith GitHub App",
            "description": {
              "content": "Install the Blacksmith GitHub App for your organization at the dashboard, then swap your runs-on tag to a Blacksmith runner label (e.g. blacksmith-2vcpu-ubuntu-2404). Not a REST call; documented here for reference.",
              "type": "text/plain"
            },
            "url": {
              "raw": "https://app.blacksmith.sh",
              "protocol": "https",
              "host": ["app", "blacksmith", "sh"],
